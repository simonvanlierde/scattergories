default:
    @just --list

install:
    @uv sync --locked

install-translation:
    @uv sync --group translation --locked

lint:
    @uv run ruff check .

format:
    @uv run ruff format .

typecheck:
    @uv run ty check

test:
    @uv run pytest

check: lint typecheck test

update:
    @uv lock --upgrade

doctor:
    @uv run sg-tools doctor

weights-sample dataset='wikitext-2':
    @uv run sg-tools weights sample --dataset {{ dataset }}

weights-sample-write dataset='wikitext-2':
    @uv run sg-tools weights sample --dataset {{ dataset }} --write

weights-locales locales='en es fr de it nl pl pt el' max_bytes='150000000':
    @uv run sg-tools weights locales --locales {{ locales }} --max-bytes {{ max_bytes }}

weights-locales-write locales='en es fr de it nl pl pt el' max_bytes='150000000':
    @uv run sg-tools weights locales --locales {{ locales }} --max-bytes {{ max_bytes }} --write-app-file

translate-categories *locales='es':
    @uv run --group translation sg-tools translate categories --target-locales {{ locales }}

translate-categories-write *locales='es':
    @uv run --group translation sg-tools translate categories --target-locales {{ locales }} --write-app-files

translate-locales *locales='es':
    @uv run --group translation sg-tools translate locales --target-locales {{ locales }}

translate-locales-write *locales='es':
    @uv run --group translation sg-tools translate locales --target-locales {{ locales }} --write-app-files

audit:
    @uv audit --preview-features audit --locked
