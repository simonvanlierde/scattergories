{
  "name": "scattergories",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell lint .",
    "check": "pnpm typecheck && pnpm spellcheck && pnpm lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "ci": "pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "i18next": "^26.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@biomejs/biome": "^2.4.12",
    "@cspell/dict-de-de": "^4.1.2",
    "@cspell/dict-el": "^3.1.8",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@cspell/dict-it-it": "^3.1.6",
    "@cspell/dict-nl-nl": "^2.4.2",
    "@cspell/dict-pl_pl": "^3.0.6",
    "@cspell/dict-pt-br": "^2.4.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "cspell": "^10.0.0",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
