{
  "name": "scattergories",
  "private": true,
  "version": "0.1.0",
  "description": "A browser-based, local-first companion for playing Scattergories at the table — locale-aware letter rolling, timer, and category packs.",
  "license": "MIT",
  "author": "Simon van Lierde <simonvanlierde@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonvanlierde/scattergories.git"
  },
  "homepage": "https://github.com/simonvanlierde/scattergories#readme",
  "bugs": "https://github.com/simonvanlierde/scattergories/issues",
  "keywords": [
    "scattergories",
    "word-game",
    "party-game",
    "react",
    "typescript",
    "vite",
    "pwa",
    "i18n"
  ],
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -b --noEmit",
    "budget": "node scripts/check-bundle-budgets.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "spellcheck": "cspell lint . --config=.cspell.yml --no-config-search --cache --cache-strategy content",
    "spellcheck-changed": "cspell lint --config=.cspell.yml --no-config-search --cache --cache-strategy content --no-progress --no-must-find-files",
    "check": "pnpm typecheck && pnpm spellcheck && pnpm lint",
    "verify": "pnpm check && pnpm test && pnpm build && pnpm budget",
    "ci": "pnpm verify && cd tools && uv sync --locked && uv run ruff check && uv run ty check && uv run pytest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --project=chromium --grep @smoke"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@cspell/dict-de-de": "^4.1.2",
    "@cspell/dict-el": "^3.1.8",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@cspell/dict-it-it": "^3.1.6",
    "@cspell/dict-nl-nl": "^2.4.2",
    "@cspell/dict-pl_pl": "^3.0.6",
    "@cspell/dict-pt-br": "^2.4.2",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "cspell": "^10.0.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
