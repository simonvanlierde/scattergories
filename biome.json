{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": ["**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "globals": ["__APP_VERSION__"]
  },
  "linter": {
    "domains": {
      "playwright": "recommended",
      "project": "recommended",
      "react": "recommended",
      "test": "recommended"
    },
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": "on",
      "complexity": "on",
      "correctness": "on",
      "security": "on",
      "suspicious": "on"
    }
  },
  "overrides": [
    {
      "includes": ["**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": {
              "level": "on",
              "options": {
                "maxLines": 60
              }
            }
          }
        }
      }
    },
    {
      "includes": ["public/sw.js"],
      "javascript": {
        "globals": ["self", "caches", "clients"]
      }
    },
    {
      "includes": ["**/*.config.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "tests/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "security": {
            "noSecrets": "off"
          },
          "style": {
            "noMagicNumbers": "off",
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ],
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
