{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": ["**", "!tools/letter_frequency/data", "!tools/letter-frequency/data"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "overrides": [
    {
      "includes": [
        "src/app.test.tsx",
        "src/game/roundReducer.test.ts",
        "src/hooks/useAudio.test.ts",
        "src/hooks/useGameSession.ts",
        "src/hooks/useKeyboardShortcuts.test.ts",
        "src/hooks/useLetterRoller.test.ts",
        "src/hooks/useRound.test.ts",
        "src/hooks/useSettings.test.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          }
        }
      }
    }
  ],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "on",
      "complexity": "on",
      "correctness": "on",
      "performance": "on",
      "security": "on",
      "style": "on",
      "suspicious": "on"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
